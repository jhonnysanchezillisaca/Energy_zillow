# Required environment variables
OPENAI_API_KEY=your_openai_api_key_here
EIA_API_KEY=your_eia_api_key_here

# Optional: defaults to 8000 locally
PORT=8000

# CORS origins (comma-separated, default allows localhost dev)
# Example: CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-vercel-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cloudflare tunnel token (required for public access via docker-compose)
# Get one from Cloudflare Zero Trust dashboard
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Data directory path (optional, defaults to ./data relative to backend)
# Example: DATA_DIR=/app/data
